{
    "name": "react-web-template",
    "private": true,
    "version": "1.0.0",
    "description": "A clean, reusable React template for building websites",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
