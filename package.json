    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@testing-library/jest-dom": "^6.1.5",
        "@testing-library/react": "^14.1.2",
        "@testing-library/user-event": "^14.5.1",
        "@types/node": "^20.10.6",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/ui": "^1.0.4",
        "autoprefixer": "^10.4.20",
