        "test:coverage": "vitest --coverage"
    },
    "dependencies": {
        "framer-motion": "^12.4.2",
        "lucide-react": "^0.344.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet-async": "^1.3.0",
        "react-router-dom": "^7.1.1",
        "zustand": "^5.0.10"
